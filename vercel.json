{
  "version": 2,
  "rewrites": [
    {
      "source": "/guida",
      "destination": "/site/guida.html"
    },
    {
      "source": "/analisi-progetto",
      "destination": "/site/analisi_progetto.html"
    },
    {
      "source": "/mappatore",
      "destination": "/site/mappatore_competenze_ada.html"
    },
    {
      "source": "/(.*)",
      "destination": "/site/$1"
    }
  ]
}